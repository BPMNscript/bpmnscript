<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:operaton="http://operaton.org/schema/1.0/bpmn"
    id="Definitions_bad"
    targetNamespace="http://bpmn.io/schema/bpmn"
    exporter="Operaton Modeler"
    exporterVersion="5.0.0">

  <bpmn:process
      id="bad-expression-process"
      name="Bad Expression Process"
      isExecutable="true"
      operaton:historyTimeToLive="P30D">

    <bpmn:startEvent id="Start_1">
      <bpmn:outgoing>Flow_Start_Service</bpmn:outgoing>
    </bpmn:startEvent>

    <!--
      This service task deliberately uses operaton:expression instead of
      operaton:class.  The BPMNscript xmlToIr transform must reject this
      with UnsupportedServiceTaskFormError — only the Java-class pattern
      (operaton:class) is supported.
    -->
    <bpmn:serviceTask
        id="BadService_1"
        name="Bad service (expression)"
        operaton:expression="${someBean.doIt()}">
      <bpmn:incoming>Flow_Start_Service</bpmn:incoming>
      <bpmn:outgoing>Flow_Service_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_1">
      <bpmn:incoming>Flow_Service_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow
        id="Flow_Start_Service"
        sourceRef="Start_1"
        targetRef="BadService_1" />

    <bpmn:sequenceFlow
        id="Flow_Service_End"
        sourceRef="BadService_1"
        targetRef="End_1" />

  </bpmn:process>

</bpmn:definitions>
