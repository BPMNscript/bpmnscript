<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:operaton="http://operaton.org/schema/1.0/bpmn"
    id="Definitions_1"
    targetNamespace="http://bpmn.io/schema/bpmn"
    exporter="Operaton Modeler"
    exporterVersion="5.0.0">

  <bpmn:process
      id="invoice-approval"
      name="Invoice Approval"
      isExecutable="true"
      operaton:historyTimeToLive="P30D">

    <bpmn:startEvent id="ReviewStart">
      <bpmn:outgoing>Flow_ReviewStart_ReviewInvoice</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask
        id="ReviewInvoice"
        name="Review invoice"
        operaton:assignee="demo">
      <bpmn:incoming>Flow_ReviewStart_ReviewInvoice</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewInvoice_AmountCheck</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway
        id="AmountCheck"
        name="Amount &gt; 1000?"
        default="AutoApprovePath">
      <bpmn:incoming>Flow_ReviewInvoice_AmountCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_SeniorBranch</bpmn:outgoing>
      <bpmn:outgoing>AutoApprovePath</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask
        id="SeniorApproval"
        name="Senior approval"
        operaton:assignee="manager">
      <bpmn:incoming>Flow_SeniorBranch</bpmn:incoming>
      <bpmn:outgoing>Flow_SeniorApproval_Done</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask
        id="AutoApprove"
        name="Auto-approve"
        operaton:class="com.example.invoice.AutoApproveDelegate">
      <bpmn:incoming>AutoApprovePath</bpmn:incoming>
      <bpmn:outgoing>Flow_AutoApprove_Done</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="Done">
      <bpmn:incoming>Flow_SeniorApproval_Done</bpmn:incoming>
      <bpmn:incoming>Flow_AutoApprove_Done</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow
        id="Flow_ReviewStart_ReviewInvoice"
        sourceRef="ReviewStart"
        targetRef="ReviewInvoice" />

    <bpmn:sequenceFlow
        id="Flow_ReviewInvoice_AmountCheck"
        sourceRef="ReviewInvoice"
        targetRef="AmountCheck" />

    <bpmn:sequenceFlow
        id="Flow_SeniorBranch"
        sourceRef="AmountCheck"
        targetRef="SeniorApproval">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${amount &gt; 1000}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow
        id="AutoApprovePath"
        sourceRef="AmountCheck"
        targetRef="AutoApprove" />

    <bpmn:sequenceFlow
        id="Flow_SeniorApproval_Done"
        sourceRef="SeniorApproval"
        targetRef="Done" />

    <bpmn:sequenceFlow
        id="Flow_AutoApprove_Done"
        sourceRef="AutoApprove"
        targetRef="Done" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="invoice-approval">

      <bpmndi:BPMNShape id="ReviewStart_di" bpmnElement="ReviewStart">
        <dc:Bounds x="152" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="ReviewInvoice_di" bpmnElement="ReviewInvoice">
        <dc:Bounds x="240" y="60" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="AmountCheck_di" bpmnElement="AmountCheck" isMarkerVisible="true">
        <dc:Bounds x="395" y="75" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="375" y="132" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="SeniorApproval_di" bpmnElement="SeniorApproval">
        <dc:Bounds x="500" y="60" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="AutoApprove_di" bpmnElement="AutoApprove">
        <dc:Bounds x="500" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Done_di" bpmnElement="Done">
        <dc:Bounds x="662" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_ReviewStart_ReviewInvoice_di" bpmnElement="Flow_ReviewStart_ReviewInvoice">
        <di:waypoint x="188" y="100" />
        <di:waypoint x="240" y="100" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_ReviewInvoice_AmountCheck_di" bpmnElement="Flow_ReviewInvoice_AmountCheck">
        <di:waypoint x="340" y="100" />
        <di:waypoint x="395" y="100" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_SeniorBranch_di" bpmnElement="Flow_SeniorBranch">
        <di:waypoint x="445" y="100" />
        <di:waypoint x="500" y="100" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="AutoApprovePath_di" bpmnElement="AutoApprovePath">
        <di:waypoint x="420" y="125" />
        <di:waypoint x="420" y="240" />
        <di:waypoint x="500" y="240" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_SeniorApproval_Done_di" bpmnElement="Flow_SeniorApproval_Done">
        <di:waypoint x="600" y="100" />
        <di:waypoint x="662" y="100" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_AutoApprove_Done_di" bpmnElement="Flow_AutoApprove_Done">
        <di:waypoint x="600" y="240" />
        <di:waypoint x="680" y="240" />
        <di:waypoint x="680" y="118" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
