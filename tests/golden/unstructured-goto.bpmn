<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:operaton="http://operaton.org/schema/1.0/bpmn"
    id="Definitions_unstructured_goto"
    targetNamespace="http://bpmn.io/schema/bpmn"
    exporter="Operaton Modeler"
    exporterVersion="5.0.0">

  <!--
    An intentionally UNSTRUCTURED process: two exclusive gateways cross-branch
    so that no single gateway post-dominates the other, and there is no shared
    join element where every branch reconverges. `RouteB` jumps into `Beta`,
    which is ALSO a direct branch target of `RouteA`, so `Beta` has two
    predecessors that originate in different gateway regions — the classic
    irreducible shape a structured `if`/`while` cannot express.

    This drives the goto-degradation import path: `xmlToIr` must read it
    without throwing (every element kind is supported and every flow resolves),
    and the restructuring `irToDsl` must fall back to `goto` for the edges it
    cannot fold into a structured block. The fixture is semantics-only for that
    test; the BPMNDI block below carries hand-picked coordinates so the file is
    a realistic modeler artefact, but `xmlToIr` discards all DI data.
  -->
  <bpmn:process id="unstructured-goto" name="Unstructured Goto" isExecutable="true" operaton:historyTimeToLive="P30D">
    <bpmn:startEvent id="Start">
      <bpmn:outgoing>Flow_Start_Intake</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Intake" name="Intake" operaton:assignee="demo">
      <bpmn:incoming>Flow_Start_Intake</bpmn:incoming>
      <bpmn:outgoing>Flow_Intake_RouteA</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="RouteA" name="Route A" default="Flow_RouteA_Beta">
      <bpmn:incoming>Flow_Intake_RouteA</bpmn:incoming>
      <bpmn:outgoing>Flow_RouteA_Alpha</bpmn:outgoing>
      <bpmn:outgoing>Flow_RouteA_Beta</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Alpha" name="Alpha" operaton:assignee="demo">
      <bpmn:incoming>Flow_RouteA_Alpha</bpmn:incoming>
      <bpmn:outgoing>Flow_Alpha_RouteB</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="RouteB" name="Route B" default="Flow_RouteB_Done">
      <bpmn:incoming>Flow_Alpha_RouteB</bpmn:incoming>
      <bpmn:outgoing>Flow_RouteB_Beta</bpmn:outgoing>
      <bpmn:outgoing>Flow_RouteB_Done</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Beta" name="Beta" operaton:assignee="manager">
      <bpmn:incoming>Flow_RouteA_Beta</bpmn:incoming>
      <bpmn:incoming>Flow_RouteB_Beta</bpmn:incoming>
      <bpmn:outgoing>Flow_Beta_DoneBeta</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Done">
      <bpmn:incoming>Flow_RouteB_Done</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="DoneBeta">
      <bpmn:incoming>Flow_Beta_DoneBeta</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Intake" sourceRef="Start" targetRef="Intake" />
    <bpmn:sequenceFlow id="Flow_Intake_RouteA" sourceRef="Intake" targetRef="RouteA" />
    <bpmn:sequenceFlow id="Flow_RouteA_Alpha" sourceRef="RouteA" targetRef="Alpha">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${route == 'A'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RouteA_Beta" sourceRef="RouteA" targetRef="Beta" />
    <bpmn:sequenceFlow id="Flow_Alpha_RouteB" sourceRef="Alpha" targetRef="RouteB" />
    <bpmn:sequenceFlow id="Flow_RouteB_Beta" sourceRef="RouteB" targetRef="Beta">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${retry == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RouteB_Done" sourceRef="RouteB" targetRef="Done" />
    <bpmn:sequenceFlow id="Flow_Beta_DoneBeta" sourceRef="Beta" targetRef="DoneBeta" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_unstructured-goto">
    <bpmndi:BPMNPlane id="BPMNPlane_unstructured-goto" bpmnElement="unstructured-goto">
      <bpmndi:BPMNShape id="Start_di" bpmnElement="Start">
        <dc:Bounds x="57" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Intake_di" bpmnElement="Intake">
        <dc:Bounds x="150" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="RouteA_di" bpmnElement="RouteA" isMarkerVisible="true">
        <dc:Bounds x="305" y="135" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Alpha_di" bpmnElement="Alpha">
        <dc:Bounds x="410" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="RouteB_di" bpmnElement="RouteB" isMarkerVisible="true">
        <dc:Bounds x="565" y="75" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Beta_di" bpmnElement="Beta">
        <dc:Bounds x="410" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Done_di" bpmnElement="Done">
        <dc:Bounds x="672" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DoneBeta_di" bpmnElement="DoneBeta">
        <dc:Bounds x="442" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Intake_di" bpmnElement="Flow_Start_Intake">
        <di:waypoint x="93" y="160" />
        <di:waypoint x="150" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Intake_RouteA_di" bpmnElement="Flow_Intake_RouteA">
        <di:waypoint x="250" y="160" />
        <di:waypoint x="305" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RouteA_Alpha_di" bpmnElement="Flow_RouteA_Alpha">
        <di:waypoint x="330" y="135" />
        <di:waypoint x="330" y="100" />
        <di:waypoint x="410" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RouteA_Beta_di" bpmnElement="Flow_RouteA_Beta">
        <di:waypoint x="330" y="185" />
        <di:waypoint x="330" y="260" />
        <di:waypoint x="410" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Alpha_RouteB_di" bpmnElement="Flow_Alpha_RouteB">
        <di:waypoint x="510" y="100" />
        <di:waypoint x="565" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RouteB_Beta_di" bpmnElement="Flow_RouteB_Beta">
        <di:waypoint x="590" y="125" />
        <di:waypoint x="590" y="260" />
        <di:waypoint x="510" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RouteB_Done_di" bpmnElement="Flow_RouteB_Done">
        <di:waypoint x="615" y="100" />
        <di:waypoint x="672" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Beta_DoneBeta_di" bpmnElement="Flow_Beta_DoneBeta">
        <di:waypoint x="460" y="300" />
        <di:waypoint x="460" y="342" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
