// structured-control-flow — a BPMNscript source that exercises every
// structured control-flow construct in a single process: `if`/`else`, `while`,
// and `parallel`. It drives the construct round-trip idempotence check
// (BPMNscript → IR → XML → IR → DSL → IR), so each construct must desugar to a
// clean, restructurable gateway shape:
//
//   `if (…) { } else { }`   → an exclusive-gateway split/join pair.
//   `while (…) { }`         → an exclusive loop gateway with a conditioned
//                             back-edge (never standardLoopCharacteristics).
//   `parallel { { } { } }`  → a parallel-gateway fork/join pair.
//
// Every flow node carries an explicit id so the round-trip can assert that
// authored ids survive; the synthesized gateway/flow ids follow the frozen
// deterministic scheme (Gateway_<coord>_split|join|loop|fork, Flow_<gw>_default).

process structured-control-flow {
  start Begin

  user Triage "Triage request" { assignee = "demo" }

  if (priority > 5) {
    user EscalateReview "Escalate review" { assignee = "manager" }
  } else {
    service AutoTriage "Auto-triage" { class = "com.example.flow.AutoTriageDelegate" }
  }

  while (retries < 3) {
    service RetryFetch "Retry fetch" { class = "com.example.flow.RetryFetchDelegate" }
  }

  parallel {
    {
      user NotifyOwner "Notify owner" { assignee = "demo" }
    }
    {
      service AuditLog "Write audit log" { class = "com.example.flow.AuditLogDelegate" }
    }
  }

  end Finish
}
