# Enforce LF line endings for text files
* text=auto eol=lf

# Explicitly declare text files
*.ts text
*.js text
*.json text
*.md text
*.yml text
*.yaml text
*.langium text

# Denote binary files
*.png binary
*.jpg binary
*.ico binary
*.gif binary
*.woff binary
*.woff2 binary

# Merge strategy for CHANGELOG
CHANGELOG.md merge=union
