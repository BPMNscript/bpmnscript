{
  "name": "vscode-bpmnscript",
  "description": "VS Code extension for BPMNscript — bundles the Langium language server",
  "version": "0.0.1",
  "displayName": "bpmnscript",
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "bpmn-script",
        "aliases": [
          "BpmnScript",
          "bpmn-script"
        ],
        "extensions": [
          ".bpmnscript"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bpmn-script",
        "scopeName": "source.bpmn-script",
        "path": "syntaxes/bpmn-script.tmLanguage.json"
      },
      {
        "scopeName": "bpmn-script.injection",
        "path": "syntaxes/bpmn-script.injection.tmLanguage.json",
        "injectTo": [
          "source.bpmn-script"
        ]
      }
    ],
    "commands": [
      {
        "command": "bpmnscript.compile",
        "title": "Compile to BPMN",
        "category": "BPMNscript"
      },
      {
        "command": "bpmnscript.decompile",
        "title": "Decompile to BPMNscript",
        "category": "BPMNscript"
      },
      {
        "command": "bpmnscript.openAndDecompile",
        "title": "Open a BPMN file and convert it…",
        "category": "BPMNscript"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bpmnscript",
          "title": "BPMNscript",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "bpmnscript": [
        {
          "type": "webview",
          "id": "bpmnscript.sidebar",
          "name": "Convert",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "bpmnscript.compile",
          "when": "resourceExtname == .bpmnscript"
        },
        {
          "command": "bpmnscript.decompile",
          "when": "resourceExtname == .bpmn"
        },
        {
          "command": "bpmnscript.openAndDecompile"
        }
      ]
    }
  },
  "main": "./out/extension/main.cjs",
  "scripts": {
    "clean": "shx rm -fr *.tsbuildinfo out syntaxes",
    "vscode:prepublish": "npm run build",
    "build:prepare": "shx mkdir -p ./syntaxes/ && shx cp -f ../language/syntaxes/bpmn-script.tmLanguage.json ./syntaxes/bpmn-script.tmLanguage.json && shx cp -f ./injection/bpmn-script.injection.tmLanguage.json ./syntaxes/bpmn-script.injection.tmLanguage.json",
    "build": "npm run build:prepare && tsc -b tsconfig.json && node esbuild.mjs",
    "build:post": "npm run build:prepare && node esbuild.mjs",
    "build:clean": "npm run clean && npm run build",
    "watch": "npm run build:prepare && concurrently -n tsc,esbuild -c blue,yellow \"tsc -b tsconfig.json --watch\" \"node esbuild.mjs --watch\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@bpmn-script/language": "0.0.1",
    "@bpmn-script/transform": "0.0.1",
    "vscode-languageclient": "~10.1.0"
  },
  "devDependencies": {
    "@types/vscode": "~1.125.0",
    "concurrently": "^9.2.3",
    "esbuild": "~0.28.1",
    "vitest": "^4.1.10"
  },
  "vsce": {
    "dependencies": false
  }
}
