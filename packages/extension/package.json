{
  "name": "vscode-bpmnscript",
  "description": "VS Code extension for BPMNscript — bundles the Langium language server",
  "version": "0.0.1",
  "displayName": "bpmnscript",
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "bpmn-script",
        "aliases": [
          "BpmnScript",
          "bpmn-script"
        ],
        "extensions": [
          ".bpmnscript"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bpmn-script",
        "scopeName": "source.bpmn-script",
        "path": "syntaxes/bpmn-script.tmLanguage.json"
      }
    ]
  },
  "main": "./out/extension/main.cjs",
  "scripts": {
    "clean": "shx rm -fr *.tsbuildinfo out syntaxes",
    "vscode:prepublish": "npm run build",
    "build:prepare": "shx mkdir -p ./syntaxes/ && shx cp -f ../language/syntaxes/bpmn-script.tmLanguage.json ./syntaxes/bpmn-script.tmLanguage.json",
    "build": "npm run build:prepare && tsc -b tsconfig.json && node esbuild.mjs",
    "build:post": "npm run build:prepare && node esbuild.mjs",
    "build:clean": "npm run clean && npm run build",
    "watch": "npm run build:prepare && concurrently -n tsc,esbuild -c blue,yellow \"tsc -b tsconfig.json --watch\" \"node esbuild.mjs --watch\""
  },
  "dependencies": {
    "@bpmn-script/language": "0.0.1",
    "vscode-languageclient": "~9.0.1",
    "vscode-languageserver": "~9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "~1.100.0",
    "concurrently": "^9.0.0",
    "esbuild": "~0.28.0"
  },
  "vsce": {
    "dependencies": false
  }
}
