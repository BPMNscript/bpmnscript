{
  "name": "@bpmn-script/transform",
  "description": "IR type definitions and bidirectional BPMN transforms for BPMNscript",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.2.3"
  },
  "files": [
    "out",
    "src"
  ],
  "main": "./out/index.js",
  "module": "./out/index.js",
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "default": "./out/index.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "out/index"
      ]
    }
  },
  "scripts": {
    "clean": "shx rm -fr *.tsbuildinfo out",
    "build": "tsc -p tsconfig.json && shx cp src/operaton-moddle.json out/",
    "build:post": "shx cp src/operaton-moddle.json out/",
    "build:clean": "npm run clean && npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "bpmn-moddle": "^10.0.0",
    "bpmn-auto-layout": "^1.2.0",
    "@bpmn-script/language": "*"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
